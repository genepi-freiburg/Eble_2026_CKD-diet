# ─────────────────────────────────────────────────────────────────────
# Environment variables required to reproduce the MR analysis
#
# USAGE:
#   1. Copy this file:    cp .env.example .env
#   2. Fill in your token (see instructions below)
#   3. Load before running R:
#        source .env && Rscript R/mr_analysis_final.R
#      OR in R directly:
#        Sys.setenv(OPENGWAS_JWT = "your_token_here")
#        source("R/mr_analysis_final.R")
#
# IMPORTANT: Never commit your .env file to Git.
#            .env is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# IEU OpenGWAS API token
# Obtain a free token at: https://api.opengwas.io/
# Log in with your institutional email, then copy the JWT token shown.
# Tokens are valid for ~14 days; regenerate as needed.
OPENGWAS_JWT=your_jwt_token_here
